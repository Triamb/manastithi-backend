# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# AI Provider - OpenRouter (FREE models available!)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (free options):
# - meta-llama/llama-3.2-3b-instruct:free (fast, good)
# - google/gemma-2-9b-it:free (smart)
# - qwen/qwen-2-7b-instruct:free (multilingual)
# Paid options (better quality):
# - anthropic/claude-3-haiku (cheap, great)
# - openai/gpt-4o-mini (cheap, great)
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Server
HOST=0.0.0.0
PORT=8000

# Frontend URL (used for redirects in OAuth callbacks, emails, etc.)
FRONTEND_URL=http://localhost:5173

# Email - Resend (https://resend.com)
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=Manastithi <onboarding@resend.dev>
SUPPORT_EMAIL=support@manastithi.com

# Google Calendar & Meet (https://console.cloud.google.com)
# 1. Create a project at https://console.cloud.google.com
# 2. Enable "Google Calendar API"
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add redirect URI: http://localhost:8000/calendar/oauth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback